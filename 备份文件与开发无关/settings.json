{
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "claude_code_attribution_header": "0"
  },
  "permissions": {
    "allow": [
      "Bash(npm run:*)",
      "Bash(powershell:*)",
      "Bash(cd E:\\\\MY AI\\\\ValQ:*)",
      "Bash(cd \"E:/MY AI/ValQ\" && node -c src/store/useVDTStore.js 2>&1)",
      "Bash(cd:*)",
      "Bash(npm install:*)"
    ],
    "defaultMode": "default"
  },
  "model": "opus[1m]",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -File \"C:/Users/shifei2/.claude/hooks/random-speak-notification.ps1\" -Category \"SessionStart\"",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -File \"C:/Users/shifei2/.claude/hooks/random-speak-notification.ps1\" -Category \"SessionEnd\"",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -File \"C:/Users/shifei2/.claude/hooks/random-speak-notification.ps1\" -Category \"UserPromptSubmit\"",
            "timeout": 30
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -File \"C:/Users/shifei2/.claude/hooks/random-speak-notification.ps1\" -Category \"PreCompact\"",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -File \"C:/Users/shifei2/.claude/hooks/random-speak-notification.ps1\" -Category \"PreToolUse\"",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -File \"C:/Users/shifei2/.claude/hooks/random-speak-notification.ps1\" -Category \"PostToolUse\"",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -File \"C:/Users/shifei2/.claude/hooks/random-speak-notification.ps1\" -Category \"PostToolUseFailure\"",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -File \"C:/Users/shifei2/.claude/hooks/random-speak-notification.ps1\" -Category \"Stop\"",
            "timeout": 30
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -File \"C:/Users/shifei2/.claude/hooks/random-speak-notification.ps1\" -Category \"Notification-permission_prompt\"",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -File \"C:/Users/shifei2/.claude/hooks/random-speak-notification.ps1\" -Category \"Notification-idle_prompt\"",
            "timeout": 30
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -File \"C:/Users/shifei2/.claude/hooks/random-speak-notification.ps1\" -Category \"SubagentStart\"",
            "timeout": 30
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -File \"C:/Users/shifei2/.claude/hooks/random-speak-notification.ps1\" -Category \"SubagentStop\"",
            "timeout": 30
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -File \"C:/Users/shifei2/.claude/hooks/random-speak-notification.ps1\" -Category \"TaskCompleted\"",
            "timeout": 30
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -File \"C:/Users/shifei2/.claude/hooks/random-speak-notification.ps1\" -Category \"PermissionRequest\"",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c 'node \"$(ls -td ~/.claude/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | head -1)dist/index.js\"'"
  },
  "enabledPlugins": {
    "claude-hud@claude-hud": true
  },
  "extraKnownMarketplaces": {
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    }
  },
  "language": "中文",
  "alwaysThinkingEnabled": false,
  "skipDangerousModePermissionPrompt": true
}
